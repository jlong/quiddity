{
  "github": {
    "displayName": "GitHub",
    "clis": [
      {
        "name": "gh",
        "installCommand": "brew install gh",
        "verifyCommand": "gh --version",
        "docsUrl": "https://cli.github.com"
      }
    ],
    "mcps": []
  },
  "github-actions": {
    "displayName": "GitHub Actions",
    "notes": "GitHub Actions runs in CI — no local CLI or MCP needed. The gh CLI (see github) can be used to check workflow run status."
  },
  "linear": {
    "displayName": "Linear",
    "clis": [
      {
        "name": "linear",
        "installCommand": "npm i -g @linear/cli",
        "verifyCommand": "linear --version",
        "docsUrl": "https://github.com/linear/linear-cli"
      }
    ],
    "mcps": [
      {
        "name": "Linear MCP",
        "package": "@linear/mcp-server",
        "docsUrl": "https://linear.app/docs/mcp"
      }
    ]
  },
  "jira": {
    "displayName": "Jira",
    "clis": [
      {
        "name": "jira",
        "installCommand": "brew install jira-cli",
